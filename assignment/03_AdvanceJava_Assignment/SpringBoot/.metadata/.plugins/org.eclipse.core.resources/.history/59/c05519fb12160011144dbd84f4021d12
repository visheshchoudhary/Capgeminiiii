package com.lpu.Boot2.Controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.HttpStatusCode;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RestController;

import com.lpu.Boot2.Entity.Company;
import com.lpu.Boot2.Entity.Employee;
import com.lpu.Boot2.Service.CompanyService;

@RestController
public class CompanyController {
	
	@Autowired
	private CompanyService service;
	
	@PostMapping("/company")
	public ResponseEntity<Company> saveCompany(@RequestBody Company company)
	{
		Company com = service.saveCompany(company);
		return ResponseEntity.status(HttpStatus.CREATED).body(com);
	}
	
	@GetMapping("/company/{id}")
	public Company findById(@PathVariable int id)
	{
		return service.findCompanyById(id); 
	}
	
	@PostMapping("/company2/{companyId}")
	public Company saveCompany2(@PathVariable int companyId,@RequestBody List<Employee> employees)
	{
		return service.saveEmployeeToExistingCompany(companyId, employees);
	}
	
	@GetMapping("/divide/{n1}/{n2}")
	public String divide(@PathVariable int n1, @PathVariable int n2)
	{
		return "Result: " + n1 / n2;
	}

}
